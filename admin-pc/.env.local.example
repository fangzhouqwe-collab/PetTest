# ==========================================
# admin-pc 独立环境配置
# 注意: 这个文件只用于后台管理系统，绝不能泄露到前端或版本控制！
# 请将 .env.local 加入 .gitignore
# ==========================================

# 与主应用相同的 Supabase URL（前台用）
VITE_SUPABASE_URL=你的_supabase项目url（如 https://xxxx.supabase.co）
VITE_SUPABASE_ANON_KEY=你的_anon_key

# ⚠️ 管理员专用 ServiceRole Key（拥有绕过 RLS 的全部权限）
# 获取方式: Supabase 控制台 → Project Settings → API → service_role (secret)
# 只在后台管理系统使用，!!!!不要用于任何用户前端!!!!
VITE_SUPABASE_SERVICE_ROLE_KEY=你的_service_role_key
